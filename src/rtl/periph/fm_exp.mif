-- fm_exp.mif -- Exponential lookup table (256x10-bit)
-- Source: OPL3 FPGA (LGPL-3.0), derived from "OPLx decapsulated"
-- Converts log-domain level back to linear amplitude
-- Usage: output = exp_lut[level & 0xFF] << (15 - (level >> 8))
-- Max output (1023 << 15) is reserved for silent/negative phase
